# Small committed dashboard assets (real, ~180KB) — keep despite the *.csv rule.
!reports/assets/*.csv
# 7MB generated interactive dashboard — rebuild via `make dashboard-static`.
docs/dashboard.html

# Secrets — zero keys in git (see ADR on security)
.env
*.env
!.env.example

# Local-only reference notes (kept out of the public repo)
ametek_*.txt

# OS / editor
.DS_Store
.idea/
.vscode/
